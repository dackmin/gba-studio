{
  "name": "gba-studio",
  "productName": "GBA Studio",
  "executableName": "GBAStudio",
  "type": "module",
  "version": "0.1.0",
  "description": "GB Studio, but worse and for the GBA",
  "main": ".vite/build/main.js",
  "author": {
    "name": "Ugo Stephant",
    "email": "ugo@poool.fr"
  },
  "license": "MIT",
  "scripts": {
    "dev": "electron-forge start",
    "package": "electron-forge package",
    "make:macos": "PLATFORM=darwin; ARCH=arm64 electron-forge make --platform=darwin --arch=arm64",
    "make:macos-intel": "PLATFORM=darwin; ARCH=x64 electron-forge make --platform=darwin --arch=x64",
    "make:win": "PLATFORM=win32; ARCH=x64 electron-forge make --platform=win32 --arch=x64",
    "make:win-32bit": "PLATFORM=win32; ARCH=ia32 electron-forge make --platform=win32 --arch=ia32",
    "make:linux": "PLATFORM=linux; ARCH=x64 electron-forge make --platform=linux --arch=x64",
    "make:linux-arm64": "PLATFORM=linux; ARCH=arm64 electron-forge make --platform=linux --arch=arm64",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --max-warnings=0 --cache .",
    "bundle:devkitPro": "node ./scripts/extract-vendor.ts devkitPro",
    "bundle:python": "node ./scripts/extract-vendor.ts python"
  },
  "peerDependencies": {
    "@neoframe/electron-window-corner-addon": "0.1.4"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/modifiers": "9.0.0",
    "@dnd-kit/sortable": "10.0.0",
    "@junipero/react": "3.13.0",
    "@junipero/theme": "3.13.0",
    "@radix-ui/react-icons": "1.3.2",
    "@radix-ui/themes": "3.3.0",
    "@thenick775/mgba-wasm": "2.4.1",
    "electron-squirrel-startup": "1.0.1",
    "fs-extra": "11.3.6",
    "handlebars": "4.7.9",
    "image-size": "2.0.2",
    "jimp": "1.6.1",
    "radix-ui": "1.4.3",
    "re-resizable": "6.11.2",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "react-hotkeys-hook": "5.3.3",
    "sharp": "0.35.3",
    "slugify": "1.6.9",
    "tar": "7.5.21",
    "uuid": "14.0.1"
  },
  "devDependencies": {
    "@bjia56/portable-python-3.13": "0.1.17",
    "@electron-forge/cli": "7.11.2",
    "@electron-forge/maker-deb": "7.11.2",
    "@electron-forge/maker-rpm": "7.11.2",
    "@electron-forge/maker-squirrel": "7.11.2",
    "@electron-forge/maker-zip": "7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "7.11.2",
    "@electron-forge/plugin-fuses": "7.11.2",
    "@electron-forge/plugin-vite": "7.11.2",
    "@electron/fuses": "2.1.3",
    "@junipero/tailwind-plugin": "3.13.0",
    "@poool/eslint-config": "6.2.0",
    "@poool/eslint-config-react": "6.2.0",
    "@reforged/maker-appimage": "5.2.0",
    "@tailwindcss/vite": "4.3.3",
    "@types/debug": "4.1.13",
    "@types/electron-squirrel-startup": "1.0.2",
    "@types/fs-extra": "11.0.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.4",
    "debug": "4.4.3",
    "dotenv": "17.4.2",
    "electron": "43.2.0",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.0.1",
    "tailwindcss": "4.3.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0",
    "vite": "8.1.5"
  },
  "build": {
    "electronLanguages": [
      "en"
    ]
  },
  "packageManager": "yarn@4.17.1"
}
